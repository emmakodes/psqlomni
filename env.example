# Preferred (works for most SQLAlchemy-supported databases):
# Example: postgresql://user:pass@localhost:5432/postgres
# Example: mysql+pymysql://user:pass@localhost:3306/mydb
# Example: sqlite:////absolute/path/to/db.sqlite
DB_URI=

# Used when DB_URI is not set.
# Examples: postgresql | mysql | mariadb | mssql+pyodbc | oracle+oracledb | sqlite
DBDIALECT=postgresql
DBHOST=localhost
DBPORT=5432
DBNAME=postgres
DBUSER=postgres
DBPASSWORD=

# openai | anthropic | google_gemini | ollama
MODEL_PROVIDER=openai
MODEL=gpt-4.1-mini
SAMPLE_ROWS_IN_TABLE_INFO=3

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Used only when MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
